{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"lib": ["ES2022", "DOM"],
		"module": "ES2022",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"noImplicitOverride": true,
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"resolveJsonModule": true
	},
	"include": ["src", "test"],
	"exclude": ["dist", "src/**/*.test.ts", "src/**/__test_helpers__"]
}
